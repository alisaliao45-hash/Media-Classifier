-- Table 1: the prompts waiting to be labeled
CREATE TABLE prompts (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    text TEXT NOT NULL,
    votes_diagram INTEGER DEFAULT 0,
    votes_video INTEGER DEFAULT 0,
    votes_audio INTEGER DEFAULT 0,
    votes_text INTEGER DEFAULT 0,
    total_votes INTEGER DEFAULT 0,
    is_finalized BOOLEAN DEFAULT 0
);

-- Table 2: individual submissions (for spam tracking + audit trail)
CREATE TABLE submissions (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    prompt_id INTEGER NOT NULL,
    session_id TEXT NOT NULL,
    label TEXT NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (prompt_id) REFERENCES prompts(id)
);

ALTER TABLE prompts ADD COLUMN is_reported BOOLEAN DEFAULT 0;
